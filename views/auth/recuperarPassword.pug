extends ../layout/index

block contenido
  div.py-10
    h1.text-4xl.my-10.font-extrabold.text-center.text-orange-400
      | Bienes 
      span.font-normal.text-black Raíces 

    h2.text-center.text-2xl.font-normal.text-black
      | Por favor ingresa cuidadosamente tus datos 

    div.mt-8.mx-auto.max-w-xl
      div.bg-white.py-8.px-6.shadow-2xl.rounded-2xl
        form.space-y-6(method="POST" action="auth/recuperarPassword")

          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
            input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400.bg-white.transition-all.duration-200(
              placeholder="jaeladrian@gmail.com"
              name="emailUsuario"
              type="email"
              required
              class="hover:shadow-sm focus:shadow-md focus:ring-2 focus:ring-orange-300 focus:outline-none"
            )

          div.px-5
            input.w-full.bg-gray-300.text-orange-400.font-bold.py-3.cursor-pointer.rounded-4xl.shadow-lg.uppercase.transition-all.duration-200(
              type="submit"
              value="Recuperar Contraseña"
            )

          div.flex.items-center.justify-between.pt-4.px-5
            a(class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition-all decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
            a(class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition-all decoration-2" href="/auth/registro") ¿No tienes cuenta? Regístrate