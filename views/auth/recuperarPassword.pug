extends ../layout/index

block contenido
  .py-10
    h1.text-4xl.my-10.font-extrabold.text-center.text-orange-400 Bienes
      span.font-normal.text-black Raíces 240784

    h2.text-center.text-2xl.font-normal.text-black Recupera tu contraseña

    .mt-8.mx-auto.max-w-xl
      .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
        if enviado
          p.px-5.mb-4.text-green-600 ✅ Solicitud enviada.

        if errores && errores.length
          ul.px-5.mb-4
            each e in errores
              li.text-red-600.text-sm= e.msg

        form.space-y-5(method="POST" action="/auth/recuperar")
          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
            input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-md-xl(
              placeholder="correo@ejemplo.com"
              name="emailUsuario"
              type="email"
              value=(datos && datos.emailUsuario ? datos.emailUsuario : "")
            )

          div.px-5
            input.w-full.bg-gray-300.text-orange-400.font-bold.py-3.cursor-pointer.rounded-4xl.shadow-lg.uppercase(
              type="submit"
              value="Recuperar Contraseña"
            )

          .flex.items-center.justify-between.pt-3
            a.text-gray-500.text-sm(href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
            a.text-gray-500.text-sm(href="/auth/registro") ¿No tienes cuenta? Regístrate