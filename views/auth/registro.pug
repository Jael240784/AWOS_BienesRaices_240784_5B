extends ../layout/index

block contenido
  .py-10
    h1.text-4xl.my-10.font-extrabold.text-center.text-orange-400 Bienes
      span.font-normal.text-black Raíces

    h2.text-center.text-2xl.font-normal.text-black Por favor ingresa cuidadosamente tus datos

    .mt-8.mx-auto.max-w-xl
      .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
        form.space-y-5(method="POST" action="/auth/registro")
          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="nombreUsuario") Nombre Completo:
            input#nombreUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-md-xl.placeholder-gray-400.bg-white.transition-all.duration-200(
              placeholder="Tu nombre completo"
              name="nombreUsuario"
              type="text"
              value=(datos?.nombreUsuario || "")
              class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300 focus:outline-none"
            )

          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
            input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-md-xl.placeholder-gray-400.bg-white.transition-all.duration-200(
              placeholder="correo@ejemplo.com"
              name="emailUsuario"
              type="email"
              value=(datos?.emailUsuario || "")
              class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300/50 focus:outline-none"
            )

          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Contraseña:
            input#passwordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-md-xl.placeholder-gray-400.bg-white.transition-all.duration-200(
              placeholder="Contraseña"
              name="passwordUsuario"
              type="password"
              class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300/50 focus:outline-none"
            )

          div.px-5
            label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmarPasswordUsuario") Confirmación de contraseña:
            input#confirmarPasswordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-md-xl.placeholder-gray-400.bg-white.transition-all.duration-200(
              placeholder="Confirmar contraseña"
              name="confirmarPasswordUsuario"
              type="password"
              class="hover:inset-shadow-sm focus:inset-shadow-xl focus:inset-shadow-orange-300/50 focus:outline-none"
            )

          input.w-full.bg-gray-300.text-orange-400.font-bold.py-3.cursor-pointer.rounded-4xl.shadow-lg.uppercase.transition-all.duration-200(
            type="submit"
            value="Registrar Usuario"
          )

          div.flex.items-center.justify-between.pt-3
            a(class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
            a(class="text-gray-500 text-sm hover:decoration-orange-400 hover:underline transition decoration-2" href="/auth/recuperarPassword") ¿Olvidaste tu contraseña? Recuperala